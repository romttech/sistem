<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RomTech - Portal do Parceiro</title>

<style>
:root{
  --azul:#2563eb;
  --bg:#0f172a;
  --card:#020617;
  --branco:#f1f5f9;
}

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:Arial, sans-serif;
}

body{
  background:var(--bg);
  color:var(--branco);
  display:flex;
  justify-content:center;
  align-items:center;
  height:100vh;
}

/* CONTAINER */
.container{
  background:var(--card);
  padding:30px;
  border-radius:12px;
  width:350px;
  text-align:center;
  box-shadow:0 0 20px rgba(0,0,0,0.5);
}

/* LOGO */
.logo{
  width:120px;
  margin-bottom:20px;
  animation: glow 2s infinite alternate;
}

@keyframes glow{
  from{
    filter: drop-shadow(0 0 5px #2563eb);
  }
  to{
    filter: drop-shadow(0 0 20px #3b82f6);
  }
}

/* INPUT */
input{
  width:100%;
  padding:12px;
  margin-bottom:10px;
  border:none;
  border-radius:6px;
}

/* BUTTON */
button{
  width:100%;
  padding:12px;
  background:var(--azul);
  border:none;
  color:white;
  border-radius:6px;
  cursor:pointer;
  margin-top:5px;
}

button:hover{
  background:#1e40af;
}

/* TOGGLE */
.toggle{
  margin-top:10px;
  font-size:14px;
  cursor:pointer;
  color:#60a5fa;
}

/* RESPONSIVO */
@media(max-width:400px){
  .container{
    width:90%;
  }
}
</style>
</head>

<body>

<div class="container">

  <img src="https://raw.githubusercontent.com/romttech/sistem/refs/heads/main/logo%20rom.png" class="logo">

  <h2 id="titulo">Acesso Parceiro</h2>

  <input type="email" id="email" placeholder="Email">
  <input type="password" id="senha" placeholder="Senha">

  <button onclick="login()" id="btn">Entrar</button>

  <div class="toggle" onclick="toggleModo()">
    Criar conta
  </div>

</div>

<!-- FIREBASE -->
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js"></script>

<script>
// FIREBASE
const firebaseConfig = {
  apiKey: "AIzaSyDfQt664GIBA50jCfi7wYxUour3kmES424",
  authDomain: "siteromtech.firebaseapp.com",
  projectId: "siteromtech"
};

firebase.initializeApp(firebaseConfig);
const auth = firebase.auth();

// CONTROLE DE MODO
let modoLogin = true;

function toggleModo(){
  modoLogin = !modoLogin;

  document.getElementById("titulo").innerText =
    modoLogin ? "Acesso Parceiro" : "Criar Conta";

  document.getElementById("btn").innerText =
    modoLogin ? "Entrar" : "Cadastrar";
}

// LOGIN / CADASTRO
function login(){
  let email = document.getElementById("email").value;
  let senha = document.getElementById("senha").value;

  if(modoLogin){
    auth.signInWithEmailAndPassword(email, senha)
      .then(()=>{
        alert("Login realizado!");
        window.location = "painel.html";
      })
      .catch(err=>alert(err.message));
  } else {
    auth.createUserWithEmailAndPassword(email, senha)
      .then(()=>{
        alert("Conta criada!");
      })
      .catch(err=>alert(err.message));
  }
}
</script>

</body>
</html>
